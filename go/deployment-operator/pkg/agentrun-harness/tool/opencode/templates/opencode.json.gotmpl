{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "analysis": {
      "description": "Analyze code for potential issues, vulnerabilities and improvements",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.1,
      "tools": {
        "plural*": true{{ if .BrowserEnabled }},
        "browser*": true{{ end }}
      },
      "permission": {
        {{- if .DindEnabled }}
        "bash": "allow",
        {{- else }}
        "bash": {
          "ls": "allow",
          "cd": "allow",
          "pwd": "allow",
          "git": "allow",
          "head": "allow",
          "tail": "allow",
          "cat": "allow",
          "grep": "allow",
          "rg": "allow",
          "find": "allow",
          "*": "deny"
        },
        {{- end }}
        "edit": "deny",
        "webfetch": "allow"
      }
    },
    "autonomous": {
      "description": "Autonomous agent for making code changes and creating pull requests",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.3,
      "tools": {
        "plural*": true,{{ if .BrowserEnabled }}
        "browser*": true,{{ end }}
        "write": false,
        "todowrite": false,
        "edit": false
      },
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "git": "deny"
      }
    }
  },
  "mcp": {
    "plural": {
      "type": "remote",
      "url": "http://127.0.0.1:8080/mcp",
      "enabled": true,
      "headers": {}
    }{{ if .BrowserEnabled }},
    "browser": {
      "type": "remote",
      "url": "{{ .BrowserMCPURL }}",
      "enabled": true,
      "headers": {}
    }{{ end }}
  },
  "username": "plural",
  "provider": {
    "{{ .Provider }}": {
      {{ if or (eq .Provider "plural") .OpenAICompatible }}"npm": "@ai-sdk/openai-compatible",
      {{ end }}"name": "{{ .Provider }}",
      "options": {
        {{- if eq .Provider "plural" }}
        "baseURL": "{{ .ConsoleURL }}/ext/ai/v1",
        "apiKey": "{{ .ConsoleToken }}"
        {{- else if .OpenAICompatible }}
        "baseURL": "{{ .Endpoint }}",
        "apiKey": "{{ .Token }}"
        {{- else }}
        {{- if .Endpoint }}
        "baseURL": "{{ .Endpoint }}",
        {{- end }}
        "apiKey": "{{ .Token }}"
        {{- end }}
      },
      "models": {
        "{{ .Model }}": {
          "name": "{{ .Model }}"
        }
      }
    }
  }
}
