{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": false,
  "agent": {
    "analysis": {
      "description": "Analyze code for potential issues, vulnerabilities and improvements",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.1,
      "tools": {
        "plural*": true
      },
      "permission": {
        {{- if .DindEnabled }}
        "bash": "allow",
        {{- else }}
        "bash": {
          "ls": "allow",
          "cd": "allow",
          "pwd": "allow",
          "git": "allow",
          "head": "allow",
          "tail": "allow",
          "cat": "allow",
          "grep": "allow",
          "rg": "allow",
          "find": "allow",
          "*": "deny"
        },
        {{- end }}
        "edit": "deny",
        "webfetch": "allow",
        "skill": {
          "*": "allow"
        }
      }
    },
    "autonomous": {
      "description": "Autonomous agent for making code changes and creating pull requests",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.3,
      "tools": {
        "plural*": true,
        "write": false,
        "todowrite": false,
        "edit": false
      },
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "git": "deny",
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "mcp": {
    "plural": {
      "type": "remote",
      "url": "http://127.0.0.1:8080/mcp",
      "enabled": true,
      "headers": {}
    }
  },
  "username": "plural",
  "provider": {
    "{{ .Provider }}": {
      {{- if or .OpenAICompatible (eq .Provider "plural") }}
      "npm": "@ai-sdk/openai",
      {{- end }}
      "name": "{{ .Provider }}",
      "options": {
        {{- if eq .Provider "plural" }}
        {{- if .StreamingProxy }}
        "baseURL": "{{ .StreamingProxyBaseURL }}",
        {{- else }}
        "baseURL": "{{ .ConsoleURL }}/ext/ai/v1",
        {{- end }}
        "apiKey": "{{ .ConsoleToken }}"
        {{- else if .OpenAICompatible }}
        "baseURL": "{{ .Endpoint }}",
        "apiKey": "{{ .Token }}"
        {{- else }}
        {{- if .Endpoint }}
        "baseURL": "{{ .Endpoint }}",
        {{- end }}
        "apiKey": "{{ .Token }}"
        {{- end }}
      },
      "models": {
        "{{ .Model }}": {
          "name": "{{ .Model }}"
        }
      }
    }
  }
}
