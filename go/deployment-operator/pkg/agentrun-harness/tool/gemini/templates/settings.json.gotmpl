{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/refs/heads/main/schemas/settings.schema.json",
  "base": {
    "modelConfig": {
      "generateContentConfig": {
        "temperature": 0.1
      }
    }
  },
  "context": {
    "fileName": "AGENTS.md"
  },
  "coreTools": {{ if eq .AgentRunMode "WRITE" }}[
    "ReadFileTool",
    "ReadManyFilesTool",
    "WriteFileTool",
    "EditTool",
    "GlobTool",
    "LSTool",
    "GrepTool",
    "ShellTool",
    "WebSearchTool",
    "WebFetchTool",
    "MemoryTool"
  ]{{ else }}[
    "ReadFileTool",
    "ReadManyFilesTool",
    "GlobTool",
    "LSTool",
    "GrepTool",
    "ShellTool(ls, cd, pwd, git status, git diff, head, tail, cat, grep, rg, find)",
    "WebSearchTool",
    "MemoryTool"
  ]{{ end }},
  "excludeTools": [
    "ShellTool(rm -rf)"
  ],
  "includeDirectories": [
    "/plural/contexts",
    "{{ .RepositoryDir }}"
  ],
  "model": {
    "name": "{{ .Model }}"
  },
  "mcpServers": {
    "plural": {
      "url": "http://127.0.0.1:8080/mcp",
      "description": "Plural MCP Server",
      "trust": true
    },
    "codebase-memory-mcp": {
      "command": "/usr/local/bin/codebase-memory-mcp",
      "args": [],
      "env": {
        "CBM_CACHE_DIR": "/plural/.cache/codebase-memory-mcp"
      },
      "description": "Codebase Memory MCP Server for graph-backed code search",
      "trust": true
    }
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "telemetry": {
    "enabled": false
  },
  "tools": {
    "shell": {
      "inactivityTimeout": {{ .InactivityTimeout }}
    }
  }
}
