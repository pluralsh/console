{
  "type": "object",
  "description": "Search repositories using the GitHub search API.",
  "properties": {
    "query": {
      "type": "string",
      "description": "Search query (GitHub repository search syntax)."
    },
    "sort": {
      "type": "string",
      "description": "Sort field: stars, forks, help-wanted-issues, updated."
    },
    "order": {
      "type": "string",
      "description": "asc or desc."
    },
    "page": {
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "description": "Page number."
    },
    "per_page": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "maximum": 100,
      "description": "Results per page."
    },
    "minimal_output": {
      "type": "boolean",
      "description": "If supported by the client/API passthrough, request reduced payload."
    }
  },
  "required": ["query"],
  "additionalProperties": false
}
