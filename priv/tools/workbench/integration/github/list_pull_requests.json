{
  "type": "object",
  "description": "List pull requests for a repository.",
  "properties": {
    "owner": {
      "type": "string",
      "description": "Repository owner."
    },
    "repo": {
      "type": "string",
      "description": "Repository name."
    },
    "state": {
      "type": "string",
      "description": "open, closed, or all."
    },
    "head": {
      "type": "string",
      "description": "Filter by head user:branch. Bare branch names default to owner:branch for this repository."
    },
    "base": {
      "type": "string",
      "description": "Filter by base branch name."
    },
    "sort": {
      "type": "string",
      "description": "created, updated, popularity, or long-running."
    },
    "direction": {
      "type": "string",
      "description": "asc or desc."
    },
    "page": {
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "description": "Page number for pagination."
    },
    "per_page": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "maximum": 100,
      "description": "Results per page."
    }
  },
  "required": ["owner", "repo"],
  "additionalProperties": false
}
