{
    "type": "object",
    "properties": {
        "q": {
            "type": "string",
            "description": "Optional prefix search on stack name"
        },
        "project": {
            "type": "string",
            "description": "Optional filter by project name, you can find the project name in the plrl_projects tool"
        },
        "status": {
            "type": "string",
            "enum": [
                "queued",
                "pending",
                "running",
                "successful",
                "failed",
                "cancelled",
                "pending_approval"
            ],
            "description": "Optional filter by stack status"
        }
    }
}
