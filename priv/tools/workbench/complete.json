{
    "type": "object",
    "properties": {
        "conclusion": {
            "type": "string",
            "description": "The conclusion to this workbench job you want to record"
        },
        "todos": {
            "type": "array",
            "description": "The todos to update.  You can add/remove/update todos if the plan needs to change, but always pass the full list of todos",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name of the todo"
                    },
                    "description": {
                        "type": "string",
                        "description": "The description of the todo"
                    },
                    "done": {
                        "type": "boolean",
                        "description": "Whether the todo is done"
                    }
                },
                "required": ["name", "description", "done"]
            }
        },
        "metrics": {
            "type": "array",
            "description": "Key metrics relevant to the conclusion to persist on the final result",
            "items": {
                "type": "object",
                "properties": {
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The timestamp of the metric"
                    },
                    "name": {
                        "type": "string",
                        "description": "The name of the metric"
                    },
                    "value": {
                        "type": "number",
                        "description": "The value of the metric"
                    },
                    "labels": {
                        "type": "object",
                        "description": "Labels for the metric"
                    }
                },
                "required": [
                    "name",
                    "value"
                ]
            }
        }
    },
    "required": [
        "conclusion"
    ]
}